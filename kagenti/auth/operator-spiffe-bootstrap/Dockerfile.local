FROM python:3.14-slim@sha256:5b3879b6f3cb77e712644d50262d05a7c146b7312d784a18eff7ff5462e77033

WORKDIR /app

# Install dependencies without hash checking for local development
RUN pip install --no-cache-dir requests==2.32.3 kubernetes==32.0.0 urllib3==2.3.0

COPY setup_operator_client.py .

USER 1001

CMD ["python", "setup_operator_client.py"]

# DEPRECATED — This file is no longer used by the Kind or OpenShift installers.
#
# The canonical secrets file is now:
#   charts/rossoctl/.secrets.yaml
#
# Create it from the template:
#   cp charts/rossoctl/.secrets_template.yaml charts/rossoctl/.secrets.yaml
#
# See docs/install.md for details.
#
# --------------------------------------------------------------------------
# Legacy format below (kept for reference only — do not use for new installs)
# --------------------------------------------------------------------------

# global secrets:
global: {}

# component-specific secrets
charts:
  rossoctl:
    values:
      secrets:
        # (Optional) Your GitHub Username — only needed to deploy agents/tools from
        # private GitHub repos or pull images from private registries:
        githubUser:
        # (Optional) Your GitHub Token — only needed for private repos/registries
        # (scopes: repo for private repos, read:packages for GHCR):
        githubToken:
        # (Optional) Your OpenAI API Key for accessing their models:
        openaiApiKey:
        # (Optional) Token for Slack Bot:
        slackBotToken: 
        # (Optional) Admin Token for Slack Bot:
        adminSlackBotToken: 
        # (Optional) Your Quay user for build-from-source.
        quayUser: 
        # (Optional) Your Quay token for building and pushing images (build-from-source).
        quayToken: